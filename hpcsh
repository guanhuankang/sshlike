#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'EOF'
usage:
  hpcsh <node> --root <shared_root> [--session <sid>] [--no-cleanup]
  hpcsh server <node> --root <shared_root>
EOF
}

if [[ $# -lt 1 ]]; then
  usage >&2
  exit 2
fi

if [[ "$1" == "server" ]]; then
  shift
  if [[ $# -lt 1 ]]; then
    usage >&2
    exit 2
  fi
  NODE="$1"
  shift
  exec python3 "${SCRIPT_DIR}/hpcsh_server.py" --node "${NODE}" "$@"
fi

NODE="$1"
shift
exec python3 "${SCRIPT_DIR}/hpcsh_client.py" --node "${NODE}" "$@"
